#ifndef BELLUM_NAVALE_CLIENT_CONFIG_HPP
#define BELLUM_NAVALE_CLIENT_CONFIG_HPP

#pragma once

#define __BUILD_OS__                  "@CMAKE_SYSTEM_NAME@"
#define __BUILD_ARCH__                "@CMAKE_SYSTEM_PROCESSOR@"
#define __BUILD_TIME__                "@CMAKE_BUILD_TIME@"
#define __BUILD_COMPILER_NAME__       "@CMAKE_CXX_COMPILER_ID@"
#define __BUILD_COMPILER_VERSION__    "@CMAKE_CXX_COMPILER_VERSION@"

#define __APP_VERSION_MAJOR__         "@APP_VERSION_MAJOR@"
#define __APP_VERSION_MINOR__         "@APP_VERSION_MINOR@"
#define __APP_VERSION_PATCH__         "@APP_VERSION_PATCH@"
#define __APP_VERSION_PRTAG__         "@APP_VERSION_PRTAG@"
#define __APP_VERSION_prtag__         "@APP_VERSION_prtag@"
#define __APP_VERSION__               __APP_VERSION_MAJOR__ "." __APP_VERSION_MINOR__ "." __APP_VERSION_PATCH__ " " __APP_VERSION_PRTAG__

#endif // BELLUM_NAVALE_CLIENT_CONFIG_HPP
